                        },
                        {
                            "id": "api",
                            "name": "api_key",
                            "value": "b5485840231d596018f5d67b50b4a05ffaaa792cec60595f",
                            "type": "string"
                        }
                    ]
                },
                "options": {}
            },
            "id": "2",
            "name": "Sync Config",
            "type": "n8n-nodes-base.set",
            "typeVersion": 3.4,
            "position": [
                50,
                200
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "=http://localhost:8081/chat/findChats/{{ encodeURIComponent($json.instance) }}",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "apikey",
                            "value": "={{ $json.api_key }}"
                        }
                    ]
                },
                "options": {}
            },
            "id": "3",
            "name": "Fetch API All",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                300,
                200
            ]
        },
        {
            "parameters": {
                "batchSize": 1,
                "options": {}
            },
            "id": "4",
            "name": "Split into Loop",
            "type": "n8n-nodes-base.splitInBatches",
            "typeVersion": 1,
            "position": [
                550,
                200
            ]
        },
        {
            "parameters": {
                "operation": "get",
                "dataTableId": "whatsapp_chats_db",
                "filters": {
                    "conditions": [
                        {
                            "columnName": "jid",
                            "operator": "equal",
                            "value": "={{ $json.id || $json.remoteJid || $json.jid }}"
                        }
                    ]
                },
                "returnAll": false,
                "options": {
                    "ignoreNoData": true
                }
            },
            "id": "5",
            "name": "Check in DB (Search JID)",
            "type": "n8n-nodes-base.dataTable",
            "typeVersion": 1,
            "position": [
                800,
                200
            ]
        },
        {
            "parameters": {
                "jsCode": "// Логика: решаем что делать (Insert, Update или Skip)\nconst apiChat = $node[\"Split into Loop\"].json;\nconst dbChat = $json;\n\nconst apiJid = apiChat.id || apiChat.remoteJid || apiChat.jid;\nconst apiName = apiChat.pushName || apiChat.name || \"Unknown\";\nconst apiType = (apiJid || \"\").endsWith('@g.us') ? 'Group' : 'Private';\n\nif (!dbChat.jid) {\n  return { action: 'insert', jid: apiJid, name: apiName, type: apiType };\n}\n\nif (dbChat.name !== apiName) {\n  return { action: 'update', rowId: dbChat.rowId, jid: apiJid, name: apiName, type: apiType };\n}\n\nreturn { action: 'skip' };"
            },
            "id": "6",
            "name": "Upsert Logic",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1050,
                200
            ]
        },
        {
            "parameters": {
                "rules": {
                    "values": [
                        {
                            "value": "insert",
                            "output": 0
                        },
                        {
                            "value": "update",
                            "output": 1
                        },
                        {
                            "value": "skip",
                            "output": 2
                        }
                    ]
                },
                "value": "={{ $json.action }}"
            },
            "id": "7",
            "name": "Action Switch",
            "type": "n8n-nodes-base.switch",
            "typeVersion": 3,
            "position": [
                1300,
                200
            ]
        },
        {
            "parameters": {
                "operation": "insert",
                "dataTableId": "whatsapp_chats_db",
                "columns": {
                    "mappingMode": "defineBelow",
                    "value": [
                        {
                            "columnName": "jid",
                            "field": "jid"
                        },
                        {
                            "columnName": "name",
                            "field": "name"
                        },
                        {
                            "columnName": "type",
                            "field": "type"
                        }
                    ]
                }
            },
            "id": "10",
            "name": "Insert NEW",
            "type": "n8n-nodes-base.dataTable",
            "typeVersion": 1,
            "position": [
                1550,
                100
            ]
        },
        {
            "parameters": {
                "operation": "update",
                "dataTableId": "whatsapp_chats_db",
                "rowId": "={{ $json.rowId }}",
                "columns": {
                    "mappingMode": "defineBelow",
                    "value": [
                        {
                            "columnName": "name",
                            "field": "name"
                        }
                    ]
                }
            },
            "id": "11",
            "name": "Update Existing",
            "type": "n8n-nodes-base.dataTable",
            "typeVersion": 1,
            "position": [
                1550,
                300
            ]
        },
        {
            "parameters": {
                "amount": 1,
                "unit": "seconds"
            },
            "id": "12",
