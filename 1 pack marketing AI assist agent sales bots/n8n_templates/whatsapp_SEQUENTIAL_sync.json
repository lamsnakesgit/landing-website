                        "index": 0
                    },
                    {
                        "node": "Fetch DB All",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Fetch DB All": {
            "main": [
                [
                    {
                        "node": "Wait for Data",
                        "type": "main",
                        "index": 1
                    }
                ]
            ]
        },
        "Wait for Data": {
            "main": [
                [
                    {
                        "node": "Bulk Sync Logic",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Bulk Sync Logic": {
            "main": [
                [
                    {
                        "node": "BULK Insert",
                        "type": "main",
                        "index": 0
                    }
                ],
                [
                    {
                        "node": "Loop for Updates",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Loop for Updates": {
            "main": [
                [
                    {
                        "node": "Update Name",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Update Name": {
