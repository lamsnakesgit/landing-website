    {
      "parameters": {
        "jsCode": "/*\\n\u0412 Evolution API, \u0435\u0441\u043b\u0438 \u0432\u043a\u043b\u044e\u0447\u0438\u0442\u044c \u043e\u043f\u0446\u0438\u044e base64 \u0432 \u0432\u0435\u0431\u0445\u0443\u043a\u0430\u0445 \u0434\u043b\u044f \u043c\u0435\u0434\u0438\u0430,\\n\u0441\u0430\u043c\u043e \u0430\u0443\u0434\u0438\u043e \u043f\u0440\u0438\u0445\u043e\u0434\u0438\u0442 \u0432 body.data.message.base64.\\n\u041d\u043e\u0434\u0430 \u0431\u0435\u0440\u0435\u0442 \u044d\u0442\u043e\u0442 base64 \u0438 \u0434\u0435\u043b\u0430\u0435\u0442 \u0438\u0437 \u043d\u0435\u0433\u043e \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0438\u0439 \u0444\u0430\u0439\u043b n8n (binary).\\n*/\\nconst item = $input.first().json;\\nconst base64Data = item.body?.data?.message?.base64;\\n\\nif (!base64Data) {\\n  throw new Error(\"\u041d\u0435 \u043d\u0430\u0439\u0434\u0435\u043d base64 \u0432 \u0432\u0435\u0431\u0445\u0443\u043a\u0435! \u0423\u0431\u0435\u0434\u0438\u0442\u0435\u0441\u044c, \u0447\u0442\u043e \u0432 Evolution API \u0432\u043a\u043b\u044e\u0447\u0435\u043d\u0430 \u043e\u043f\u0446\u0438\u044f \u043e\u0442\u043f\u0440\u0430\u0432\u043a\u0438 base64 \u0434\u043b\u044f \u043c\u0435\u0434\u0438\u0430 \u0432 \u0432\u0435\u0431\u0445\u0443\u043a\u0430\u0445.\");\\n}\\n\\nconst buffer = Buffer.from(base64Data, 'base64');\\n\\nreturn {\\n  json: item,\\n  binary: {\\n    data: {\\n      data: buffer.toString('base64'),\\n      mimeType: 'audio/ogg',\\n      fileName: 'voice.ogg'\\n    }\\n  }\\n};"
      },
