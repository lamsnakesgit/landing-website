          }
        ],
        [
          {
            "node": "FFmpeg: Concatenate & Cleanup",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "HTTP: Imagen 3": {
      "main": [
        [
          {
            "node": "Base64 to Image",
